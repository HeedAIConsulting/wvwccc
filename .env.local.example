# Copy this file to ".env.local" (gitignored) and fill in real values.
# Loaded automatically by `npm start` / `npm run dev` (node --env-file-if-exists).
# In PRODUCTION (Render) set these in the dashboard instead — NOT in a file.

# ── AI Concierge / smart search (Google Gemini) ──
# Get a key at https://aistudio.google.com/apikey . Always uses gemini-flash-latest.
GEMINI_API_KEY=

# ── Optional fallback LLM (Anthropic) ──
ANTHROPIC_API_KEY=

# ── Local dev niceties ──
# PORT=5500
# NODE_ENV=development

# ── CAPTCHA (Cloudflare Turnstile) ──
# Site key goes in js/api-base.js (public); secret here (server-only).
TURNSTILE_SECRET=

# ── Transactional email (Microsoft 365 SMTP) ──
# Enable SMTP AUTH for the mailbox + create an app password (if MFA).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=wendy@woodlandhillscc.net
SMTP_PASS=
# CHAMBER_NOTIFY=wendy@woodlandhillscc.net   # where website inquiries are sent
# SITE_URL=https://wvwccc-chamber-api.onrender.com   # base for reset links
