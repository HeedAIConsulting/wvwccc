# WVWCCC production env — copy to .env.local (gitignored) and fill real values.
# NEVER commit real keys.

# ── Core ──
NODE_ENV=development
# Postgres (production). Leave UNSET in dev → app uses the JSON store automatically.
DATABASE_URL=
# Session signing secret (REQUIRED in production; Render generates one via render.yaml).
JWT_SECRET=

# ── AI Concierge (server-side only) ──
GEMINI_API_KEY=          # Heed Gemini key; always use gemini-flash-latest
ANTHROPIC_API_KEY=       # optional fallback

# ── Payments: AGMS / NMI gateway (merchant of record = the Chamber) ──
# Gateway: Avant Garde Marketing Solutions on the NMI/transactiongateway.com platform.
# Get the Security Key from the gateway: Settings → Security Keys (use the SANDBOX key first).
AGMS_SECURITY_KEY=
AGMS_USERNAME=heedaisolutions
# Sandbox vs production base URL:
#   sandbox    https://sandbox.nmi.com
#   production https://agms.transactiongateway.com
AGMS_API_BASE=https://sandbox.nmi.com

# ── Heed revenue share ──
HEED_REVENUE_SHARE=0.15
